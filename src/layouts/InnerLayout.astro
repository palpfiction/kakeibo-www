---
import type { Locale, Translations } from "../i18n";
import { SITE_URL } from "../consts";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import PageHeader from "../components/PageHeader.astro";
import PageFooter from "../components/PageFooter.astro";

interface Props {
    locale: Locale;
    t: Translations;
    /** Page-specific <title> */
    title: string;
    /** Page-specific <meta description> */
    description: string;
    /** Canonical path segment, e.g. "privacy" → /en/privacy/ */
    path: string;
}

const { locale, t, title, description, path } = Astro.props;

const canonicalUrl = `${SITE_URL}/${locale}/${path}/`;
const ogLocaleMap: Record<Locale, string> = { en: "en_US", es: "es_ES" };
const alternateLocale = locale === "en" ? "es" : "en";
const ogImageUrl = `${SITE_URL}/ogimage.png`;
---

<!doctype html>
<html lang={locale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/ogimage.png" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400&family=Sora:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#0c0d0d" />
        <meta name="description" content={description} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:locale" content={ogLocaleMap[locale]} />
        <meta property="og:locale:alternate" content={ogLocaleMap[alternateLocale]} />
        <meta property="og:site_name" content={t.footer.appName} />
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />
        <link rel="alternate" hreflang="en" href={`${SITE_URL}/en/${path}/`} />
        <link rel="alternate" hreflang="es" href={`${SITE_URL}/es/${path}/`} />
        <link
            rel="alternate"
            hreflang="x-default"
            href={`${SITE_URL}/en/${path}/`}
        />
        <title>{title}</title>
    </head>
    <body>
        <PageHeader locale={locale} t={t}>
            <LanguageSwitcher locale={locale} t={t} path={path} fixed={false} />
        </PageHeader>
        <main class="inner-main">
            <slot />
        </main>
        <PageFooter locale={locale} t={t} />
    </body>
</html>

<style is:global>
    :root {
        /* Colors */
        --bg: #0c0d0d;
        --bg-elevated: #141515;
        --surface: #1e1f20;
        --surface-hover: #2a2b2c;
        --surface-light: #3e3e3e;
        --text: #ffffff;
        --text-secondary: #c0c0c0;
        --subtext: #8f8f8f;
        --red: #ef476f;
        --blue: #118ab2;
        --green: #06d6a0;
        --yellow: #ffd166;
        --dark-blue: #073b4c;
        --dark-green: #037c5d;
        --dark-yellow: #cc8f00;
        --border: rgba(255, 255, 255, 0.06);
        --border-light: rgba(255, 255, 255, 0.1);

        /* Spacing */
        --space-xs: 4px;
        --space-sm: 8px;
        --space-md: 16px;
        --space-lg: 24px;
        --space-xl: 32px;
        --space-2xl: 48px;
        --space-3xl: 64px;
        --space-4xl: 96px;

        /* Border radius */
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 16px;
        --radius-xl: 24px;
        --radius-pill: 999px;

        /* Max widths */
        --max-width: 1120px;
        --max-width-narrow: 720px;

        /* Transitions */
        --transition-fast: 150ms ease;
        --transition-normal: 250ms ease;
        --transition-slow: 400ms ease;
    }

    html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    *,
    *::before,
    *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family:
            "Inter",
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
    }

    img {
        max-width: 100%;
        height: auto;
        display: block;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    .fade-in {
        opacity: 0;
        transform: translateY(24px);
        transition:
            opacity 0.6s ease,
            transform 0.6s ease;
    }

    .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .fade-in-delay-1 { transition-delay: 0.1s; }
    .fade-in-delay-2 { transition-delay: 0.2s; }
    .fade-in-delay-3 { transition-delay: 0.3s; }
    .fade-in-delay-4 { transition-delay: 0.4s; }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }

    /* Inner page content wrapper */
    .inner-main {
        max-width: var(--max-width-narrow);
        margin: 0 auto;
        padding: var(--space-4xl) var(--space-lg) var(--space-3xl);
    }

    @media (max-width: 640px) {
        .inner-main {
            padding: var(--space-3xl) var(--space-md) var(--space-2xl);
        }
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                }
            });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );

    document.querySelectorAll(".fade-in").forEach((el) => {
        observer.observe(el);
    });
</script>
