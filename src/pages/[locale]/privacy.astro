---
import type { GetStaticPaths } from "astro";
import { locales, getTranslations, type Locale } from "../../i18n";
import InnerLayout from "../../layouts/InnerLayout.astro";

export const getStaticPaths: GetStaticPaths = () => {
    return locales.map((locale) => ({
        params: { locale },
    }));
};

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const p = t.privacyPage;
---

<InnerLayout
    locale={locale}
    t={t}
    title={p.meta.title}
    description={p.meta.description}
    path="privacy"
>
    <h1 class="page-heading">{p.heading}</h1>
    <p class="last-updated">{p.lastUpdated}</p>

    <div class="content-card">
        <p class="highlight">{p.highlight}</p>

        <div class="section-block">
            <h2>{p.section1.title}</h2>
            <p>{p.section1.p1}</p>
        </div>

        <div class="section-block">
            <h2>{p.section2.title}</h2>
            <p>{p.section2.intro}</p>
            <ul>
                {p.section2.items.map((item: string) => <li>{item}</li>)}
            </ul>
        </div>

        <div class="section-block">
            <h2>{p.section3.title}</h2>
            <p>{p.section3.p1}</p>
            <p>{p.section3.p2}</p>
        </div>

        <div class="section-block">
            <h2>{p.section4.title}</h2>
            <p>{p.section4.p1}</p>
        </div>
    </div>
</InnerLayout>

<style>
    .page-heading {
        font-family: "Sora", sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: var(--space-md);
    }

    .last-updated {
        font-family: "JetBrains Mono", "Fira Mono", "Courier New", monospace;
        font-size: 0.75rem;
        color: var(--subtext);
        letter-spacing: 0.04em;
        margin-bottom: var(--space-3xl);
        opacity: 0.7;
    }

    .content-card {
        background: var(--surface);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        overflow: hidden;
    }

    .highlight {
        font-family: "Sora", sans-serif;
        color: var(--green);
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        padding: var(--space-xl);
        border-bottom: 1px solid var(--border);
        margin: 0;
    }

    .section-block {
        padding: var(--space-xl);
        border-bottom: 1px solid var(--border);
    }

    .section-block:last-child {
        border-bottom: none;
    }

    h2 {
        font-family: "Sora", sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--subtext);
        margin-bottom: var(--space-md);
    }

    p {
        color: var(--text-secondary);
        line-height: 1.75;
        margin-bottom: var(--space-sm);
    }

    p:last-child {
        margin-bottom: 0;
    }

    ul {
        margin-top: var(--space-sm);
        padding-left: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
    }

    li {
        color: var(--text-secondary);
        line-height: 1.6;
        padding-left: var(--space-xs);
    }

    li::marker {
        color: var(--green);
    }

    @media (max-width: 640px) {
        .highlight,
        .section-block {
            padding: var(--space-lg);
        }
    }
</style>
