---
// Root page: auto-detects locale and redirects to /en/ or /es/
// Uses client-side detection since this is a static site.
// Canonical points to /en/ so search engines consolidate link equity there.
// The noscript fallback also redirects to /en/.
import { getTranslations } from "../i18n";

const t = getTranslations("en");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="canonical" href="https://getkakeibo.com/en/" />
        <title>{t.meta.title}</title>
        <meta name="description" content={t.meta.description} />
        <link rel="alternate" hreflang="en" href="https://getkakeibo.com/en/" />
        <link rel="alternate" hreflang="es" href="https://getkakeibo.com/es/" />
        <link
            rel="alternate"
            hreflang="x-default"
            href="https://getkakeibo.com/en/"
        />
        <script is:inline>
            (function () {
                var supported = ["en", "es"];
                var langs = navigator.languages || [navigator.language || "en"];
                var locale = "en";
                for (var i = 0; i < langs.length; i++) {
                    var lang = langs[i].toLowerCase().split("-")[0];
                    if (supported.indexOf(lang) !== -1) {
                        locale = lang;
                        break;
                    }
                }
                window.location.replace("/" + locale + "/");
            })();
        </script>
    </head>
    <body>
        <noscript>
            <meta http-equiv="refresh" content="0;url=/en/" />
        </noscript>
    </body>
</html>
