---

---

<section class="section features" id="features">
    <div class="section-inner">
        <div class="section-header fade-in">
            <h2 class="section-title">
                Everything you need,<br />nothing you don't
            </h2>
            <p class="section-subtitle">
                Simple by design. No feature bloat, no complexity. Every screen
                serves a purpose.
            </p>
        </div>

        <!-- Feature 1: Budget Wizard -->
        <div class="feature-row fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(6, 214, 160, 0.12); color: var(--green);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M12 20h9"></path><path
                            d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
                        ></path>
                    </svg>
                </div>
                <h3>Monthly budget wizard</h3>
                <p>
                    Start each month with clarity. A simple, guided wizard walks
                    you through setting your income, fixed expenses, and savings
                    goals. Copy from last month to save time.
                </p>
                <ul class="feature-bullets">
                    <li>Step-by-step budget creation</li>
                    <li>Copy previous month's setup</li>
                    <li>Set savings goals and promises to yourself</li>
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src="/screenshots/en/budget.jpeg"
                    alt="Budget wizard showing fixed expenses"
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- Feature 2: Statistics -->
        <div class="feature-row reverse fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(17, 138, 178, 0.12); color: var(--blue);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M3 3v18h18"></path><path d="m19 9-5 5-4-4-3 3"
                        ></path>
                    </svg>
                </div>
                <h3>Clear, beautiful statistics</h3>
                <p>
                    See your spending patterns at a glance. Weekly, monthly, or
                    yearly, with category breakdowns, daily averages, and period
                    comparisons that actually make sense.
                </p>
                <ul class="feature-bullets">
                    <li>Week, month, and year views</li>
                    <li>Category and tag breakdowns</li>
                    <li>Compare against previous periods</li>
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src="/screenshots/en/statistics.png"
                    alt="Statistics showing spending breakdown"
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- Feature 3: Reflection -->
        <div class="feature-row fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(255, 209, 102, 0.12); color: var(--yellow);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
                        ></path>
                    </svg>
                </div>
                <h3>Month-end reflection</h3>
                <p>
                    This is the heart of Kakeibo. A guided reflection that walks
                    you through your month, week by week, category by category,
                    tag by tag. Did you keep your promises? What will you do
                    differently?
                </p>
                <ul class="feature-bullets">
                    <li>Guided 5-step review process</li>
                    <li>Week-by-week spending breakdown</li>
                    <li>Personal goals and promises check-in</li>
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src="/screenshots/en/howyoudo.jpeg"
                    alt="Month-end reflection"
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- Feature 4: Tags -->
        <div class="feature-row reverse fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(239, 71, 111, 0.12); color: var(--red);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"
                        ></path><path d="M7 7h.01"></path>
                    </svg>
                </div>
                <h3>Custom tags</h3>
                <p>
                    Tags cut across categories. Track vacation spending, work
                    meals, or any theme that matters to you. Each tag gets its
                    own emoji so you can spot patterns instantly.
                </p>
                <ul class="feature-bullets">
                    <li>Create custom tags with emoji labels</li>
                    <li>Emoji labels for quick recognition</li>
                    <li>Cross-category expense tracking</li>
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src="/screenshots/en/tags.png"
                    alt="Custom tags feature"
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- More features grid -->
        <div class="features-mini-grid">
            <div class="mini-feature fade-in">
                <div
                    class="mini-icon"
                    style="background: rgba(6, 214, 160, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--green)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.35-4.35"></path>
                    </svg>
                </div>
                <h4>Search & filter</h4>
                <p>
                    Find any transaction instantly. Filter by date, category,
                    tag, or type.
                </p>
            </div>
            <div class="mini-feature fade-in fade-in-delay-1">
                <div
                    class="mini-icon"
                    style="background: rgba(17, 138, 178, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--blue)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                        ></path><polyline points="7 10 12 15 17 10"
                        ></polyline><line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </div>
                <h4>Data export</h4>
                <p>
                    Export your data anytime. It's your data: take it wherever
                    you want.
                </p>
            </div>
            <div class="mini-feature fade-in fade-in-delay-2">
                <div
                    class="mini-icon"
                    style="background: rgba(255, 209, 102, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--yellow)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"
                        ></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path>
                    </svg>
                </div>
                <h4>Respectful reminders</h4>
                <p>
                    Gentle daily, weekly, or monthly nudges to keep your
                    tracking habit alive.
                </p>
            </div>
            <div class="mini-feature fade-in fade-in-delay-3">
                <div
                    class="mini-icon"
                    style="background: rgba(239, 71, 111, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--red)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="12" cy="12" r="10"></circle><path
                            d="M2 12h20"></path><path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                        ></path>
                    </svg>
                </div>
                <h4>27 currencies</h4>
                <p>
                    From USD to JPY to EUR. Use the currency that matches your
                    life.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .features {
        background: var(--bg);
    }

    .feature-row {
        display: flex;
        align-items: center;
        gap: var(--space-3xl);
        margin-bottom: var(--space-4xl);
    }

    .feature-row.reverse {
        flex-direction: row-reverse;
    }

    .feature-text {
        flex: 1;
    }

    .feature-visual {
        flex: 1;
        display: flex;
        justify-content: center;
    }

    .feature-visual .screenshot {
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-light);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .feature-badge {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-md);
    }

    .feature-text h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: var(--space-md);
        letter-spacing: -0.01em;
    }

    .feature-text p {
        font-size: 1rem;
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-lg);
    }

    .feature-bullets {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .feature-bullets li {
        font-size: 0.9rem;
        color: var(--text-secondary);
        padding-left: 20px;
        position: relative;
    }

    .feature-bullets li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 8px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
    }

    /* Mock: Budget Wizard */
    .mock-wizard {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
        width: 100%;
        max-width: 380px;
    }

    .mock-wizard-progress {
        display: flex;
        gap: 6px;
        margin-bottom: var(--space-lg);
    }

    .mock-progress-step {
        flex: 1;
        height: 4px;
        border-radius: var(--radius-pill);
        background: var(--surface);
    }

    .mock-progress-step.active {
        background: var(--blue);
    }

    .mock-wizard-title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: var(--space-xs);
    }

    .mock-wizard-subtitle {
        font-size: 0.85rem;
        color: var(--subtext);
        margin-bottom: var(--space-lg);
    }

    .mock-expense-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .mock-expense {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        background: var(--surface);
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
    }

    .mock-expense-name {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .mock-expense-amount {
        font-size: 0.9rem;
        font-weight: 700;
    }

    .mock-add-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-sm);
        padding: 12px;
        border: 1.5px dashed var(--border-light);
        border-radius: var(--radius-md);
        color: var(--blue);
        font-size: 0.85rem;
        font-weight: 500;
    }

    /* Mock: Stats */
    .mock-stats {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
        width: 100%;
        max-width: 380px;
    }

    .mock-stats-header {
        margin-bottom: var(--space-lg);
    }

    .mock-period-tabs {
        display: flex;
        gap: 4px;
        background: var(--surface);
        border-radius: var(--radius-md);
        padding: 3px;
    }

    .mock-tab {
        flex: 1;
        text-align: center;
        font-size: 0.8rem;
        font-weight: 500;
        padding: 6px 12px;
        border-radius: 6px;
        color: var(--subtext);
    }

    .mock-tab.active {
        background: var(--blue);
        color: var(--text);
    }

    .mock-stat-cards {
        display: flex;
        gap: var(--space-sm);
        margin-bottom: var(--space-lg);
    }

    .mock-stat-card {
        flex: 1;
        background: var(--surface);
        border-radius: var(--radius-md);
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mock-stat-label {
        font-size: 0.7rem;
        color: var(--subtext);
    }

    .mock-stat-value {
        font-size: 1.25rem;
        font-weight: 700;
    }

    .mock-breakdown {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .mock-breakdown-row {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
    }

    .mock-breakdown-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .mock-breakdown-name {
        font-size: 0.8rem;
        font-weight: 500;
        width: 76px;
        flex-shrink: 0;
    }

    .mock-breakdown-bar-track {
        flex: 1;
        height: 6px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: var(--radius-pill);
        overflow: hidden;
    }

    .mock-breakdown-bar {
        height: 100%;
        border-radius: var(--radius-pill);
    }

    .mock-breakdown-amount {
        font-size: 0.8rem;
        font-weight: 700;
        width: 44px;
        text-align: right;
        flex-shrink: 0;
    }

    /* Mock: Reflection */
    .mock-reflection {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
        width: 100%;
        max-width: 380px;
    }

    .mock-reflection-header {
        text-align: center;
        margin-bottom: var(--space-lg);
    }

    .mock-sparkle {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-md);
        background: rgba(255, 209, 102, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--space-md);
    }

    .mock-reflection-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .mock-reflection-subtitle {
        font-size: 0.8rem;
        color: var(--subtext);
    }

    .mock-reflection-stats {
        display: flex;
        gap: var(--space-md);
        margin-bottom: var(--space-lg);
    }

    .mock-reflection-stat {
        flex: 1;
        background: var(--surface);
        border-radius: var(--radius-md);
        padding: var(--space-md);
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mock-reflection-stat-value {
        font-size: 1.25rem;
        font-weight: 700;
    }

    .mock-reflection-stat-value.green {
        color: var(--green);
    }

    .mock-reflection-stat-label {
        font-size: 0.7rem;
        color: var(--subtext);
    }

    .mock-reflection-question {
        background: var(--surface);
        border-radius: var(--radius-md);
        padding: var(--space-md);
    }

    .mock-q-label {
        font-size: 0.85rem;
        font-weight: 600;
        display: block;
        margin-bottom: var(--space-sm);
    }

    .mock-q-options {
        display: flex;
        gap: var(--space-sm);
    }

    .mock-q-option {
        font-size: 0.75rem;
        padding: 6px 12px;
        border-radius: var(--radius-pill);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--border);
        cursor: default;
    }

    .mock-q-option.selected {
        background: rgba(17, 138, 178, 0.15);
        border-color: var(--blue);
        color: var(--blue);
    }

    /* Mock: Tags */
    .mock-tags {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
        width: 100%;
        max-width: 380px;
    }

    .mock-tags-title {
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: var(--space-md);
        color: var(--subtext);
    }

    .mock-tags-grid {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
        margin-bottom: var(--space-lg);
    }

    .mock-tag-chip {
        font-size: 0.8rem;
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--border);
    }

    .mock-tag-stats {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        border-top: 1px solid var(--border);
        padding-top: var(--space-md);
    }

    .mock-tag-stat-row {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        font-size: 0.8rem;
    }

    .mock-tag-stat-label {
        font-weight: 500;
        flex: 1;
    }

    .mock-tag-stat-count {
        color: var(--subtext);
        font-size: 0.7rem;
    }

    .mock-tag-stat-amount {
        font-weight: 700;
        width: 48px;
        text-align: right;
    }

    /* Mini features grid */
    .features-mini-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-lg);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--border);
    }

    .mini-feature {
        text-align: center;
    }

    .mini-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--space-md);
    }

    .mini-feature h4 {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: var(--space-xs);
    }

    .mini-feature p {
        font-size: 0.85rem;
        color: var(--subtext);
        line-height: 1.6;
    }

    @media (max-width: 900px) {
        .feature-row,
        .feature-row.reverse {
            flex-direction: column;
        }

        .feature-visual {
            width: 100%;
        }
    }

    @media (max-width: 768px) {
        .features-mini-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .features-mini-grid {
            grid-template-columns: 1fr;
        }

        .mock-q-options {
            flex-direction: column;
        }
    }
</style>
