---
import type { Locale, Translations } from "../i18n";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props;
const f = t.features;
---

<section class="section features" id="features">
    <div class="section-inner">
        <div class="section-header fade-in">
            <h2
                class="section-title"
                set:html={f.title.replace("\n", "<br />")}
            />
            <p class="section-subtitle">{f.subtitle}</p>
        </div>

        <!-- Feature 1: Budget Wizard -->
        <div class="feature-row fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(6, 214, 160, 0.12); color: var(--green);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M12 20h9"></path><path
                            d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
                        ></path>
                    </svg>
                </div>
                <h3>{f.budget.title}</h3>
                <p>{f.budget.description}</p>
                <ul class="feature-bullets">
                    {f.budget.bullets.map((b: string) => <li>{b}</li>)}
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src={`/screenshots/${locale}/budget.png`}
                    alt={f.budget.screenshotAlt}
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- Feature 2: Statistics -->
        <div class="feature-row reverse fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(17, 138, 178, 0.12); color: var(--blue);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M3 3v18h18"></path><path d="m19 9-5 5-4-4-3 3"
                        ></path>
                    </svg>
                </div>
                <h3>{f.statistics.title}</h3>
                <p>{f.statistics.description}</p>
                <ul class="feature-bullets">
                    {f.statistics.bullets.map((b: string) => <li>{b}</li>)}
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src={`/screenshots/${locale}/statistics.png`}
                    alt={f.statistics.screenshotAlt}
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- Feature 3: Reflection -->
        <div class="feature-row fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(255, 209, 102, 0.12); color: var(--yellow);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
                        ></path>
                    </svg>
                </div>
                <h3>{f.reflection.title}</h3>
                <p>{f.reflection.description}</p>
                <ul class="feature-bullets">
                    {f.reflection.bullets.map((b: string) => <li>{b}</li>)}
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src={`/screenshots/${locale}/howyoudo.png`}
                    alt={f.reflection.screenshotAlt}
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- Feature 4: Tags -->
        <div class="feature-row reverse fade-in">
            <div class="feature-text">
                <div
                    class="feature-badge"
                    style="background: rgba(239, 71, 111, 0.12); color: var(--red);"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"
                        ></path><path d="M7 7h.01"></path>
                    </svg>
                </div>
                <h3>{f.tags.title}</h3>
                <p>{f.tags.description}</p>
                <ul class="feature-bullets">
                    {f.tags.bullets.map((b: string) => <li>{b}</li>)}
                </ul>
            </div>
            <div class="feature-visual">
                <img
                    src={`/screenshots/${locale}/tags.png`}
                    alt={f.tags.screenshotAlt}
                    width="380"
                    class="screenshot"
                />
            </div>
        </div>

        <!-- More features grid -->
        <div class="features-mini-grid">
            <div class="mini-feature fade-in">
                <div
                    class="mini-icon"
                    style="background: rgba(6, 214, 160, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--green)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.35-4.35"></path>
                    </svg>
                </div>
                <h4>{f.mini.search.title}</h4>
                <p>{f.mini.search.description}</p>
            </div>
            <div class="mini-feature fade-in fade-in-delay-1">
                <div
                    class="mini-icon"
                    style="background: rgba(17, 138, 178, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--blue)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                        ></path><polyline points="7 10 12 15 17 10"
                        ></polyline><line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </div>
                <h4>{f.mini.export.title}</h4>
                <p>{f.mini.export.description}</p>
            </div>
            <div class="mini-feature fade-in fade-in-delay-2">
                <div
                    class="mini-icon"
                    style="background: rgba(255, 209, 102, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--yellow)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"
                        ></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path>
                    </svg>
                </div>
                <h4>{f.mini.reminders.title}</h4>
                <p>{f.mini.reminders.description}</p>
            </div>
            <div class="mini-feature fade-in fade-in-delay-3">
                <div
                    class="mini-icon"
                    style="background: rgba(239, 71, 111, 0.12);"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--red)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="12" cy="12" r="10"></circle><path
                            d="M2 12h20"></path><path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                        ></path>
                    </svg>
                </div>
                <h4>{f.mini.currencies.title}</h4>
                <p>{f.mini.currencies.description}</p>
            </div>
        </div>
    </div>
</section>

<style>
    .features {
        background: var(--bg);
    }

    .feature-row {
        display: flex;
        align-items: center;
        gap: var(--space-3xl);
        margin-bottom: var(--space-4xl);
    }

    .feature-row.reverse {
        flex-direction: row-reverse;
    }

    .feature-text {
        flex: 1;
    }

    .feature-visual {
        flex: 1;
        display: flex;
        justify-content: center;
    }

    .feature-visual .screenshot {
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-light);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .feature-badge {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-md);
    }

    .feature-text h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: var(--space-md);
        letter-spacing: -0.01em;
    }

    .feature-text p {
        font-size: 1rem;
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-lg);
    }

    .feature-bullets {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .feature-bullets li {
        font-size: 0.9rem;
        color: var(--text-secondary);
        padding-left: 20px;
        position: relative;
    }

    .feature-bullets li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 8px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
    }

    /* Mini features grid */
    .features-mini-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-lg);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--border);
    }

    .mini-feature {
        text-align: center;
    }

    .mini-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--space-md);
    }

    .mini-feature h4 {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: var(--space-xs);
    }

    .mini-feature p {
        font-size: 0.85rem;
        color: var(--subtext);
        line-height: 1.6;
    }

    @media (max-width: 900px) {
        .feature-row,
        .feature-row.reverse {
            flex-direction: column;
        }

        .feature-visual {
            width: 100%;
        }
    }

    @media (max-width: 768px) {
        .features-mini-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .features-mini-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
