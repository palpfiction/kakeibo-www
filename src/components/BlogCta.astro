---
import type { Locale, Translations } from "../i18n";
import AppDownload from "./AppDownload.astro";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props as Props;
const blogT = t.blog.listing;
---

<section class="blog-cta">
    <div class="copy">
        <h2>{blogT.ctaTitle}</h2>
        <p class="description">{blogT.ctaDescription}</p>
    </div>

    <div class="actions">
        <AppDownload />
    </div>
</section>

<style>
    .blog-cta {
        margin-top: var(--space-3xl);
        padding: var(--space-xl);
        border-radius: var(--radius-xl);
        border: 1px solid rgba(6, 214, 160, 0.18);
        background:
            radial-gradient(
                circle at top right,
                rgba(255, 209, 102, 0.12),
                transparent 32%
            ),
            linear-gradient(
                135deg,
                rgba(6, 214, 160, 0.16),
                rgba(17, 138, 178, 0.12) 58%,
                rgba(12, 13, 13, 0.4)
            );
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
        overflow: hidden;
        position: relative;
        display: grid;
        gap: var(--space-lg);
    }

    .blog-cta::before {
        content: "";
        position: absolute;
        right: -100px;
        bottom: -120px;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(17, 138, 178, 0.22),
            transparent 68%
        );
        pointer-events: none;
    }

    h2 {
        font-family: "Sora", sans-serif;
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: var(--space-sm);
    }

    .description {
        color: rgba(255, 255, 255, 0.82);
        line-height: 1.75;
        max-width: 58ch;
    }

    .copy,
    .actions {
        position: relative;
        z-index: 1;
    }

    .actions {
        padding-top: var(--space-md);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }


    .blog-cta :global(.store-btn) {
        background: rgba(12, 13, 13, 0.36);
        border-color: rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(10px);
    }

    .blog-cta :global(.store-btn:hover) {
        background: rgba(12, 13, 13, 0.5);
        border-color: rgba(255, 255, 255, 0.2);
    }

    @media (max-width: 640px) {
        .blog-cta {
            padding: var(--space-lg);
        }
    }
</style>
