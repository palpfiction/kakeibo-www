---
import type { Locale, Translations } from "../i18n";
import { Image } from "astro:assets";
import icon from "../assets/icon.svg";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props;
const ft = t.footer;
---

<footer class="footer">
    <div class="footer-inner">
        <div class="footer-left">
            <a href={`/${locale}/`} class="footer-logo">
                <Image src={icon} width={24} height={24} alt="" />
                <span>{ft.appName}</span>
            </a>
            <p class="footer-tagline">{ft.tagline}</p>
        </div>
        <div class="footer-right">
            <a href={`/${locale}/privacy/`}>{ft.privacyPolicy}</a>
            <a href="mailto:hola@getkakeibo.com">{ft.contact}</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} {ft.appName}. {ft.rights}</p>
    </div>
</footer>

<style>
    .footer {
        background: var(--bg);
        border-top: 1px solid var(--border);
        padding: var(--space-2xl) var(--space-lg);
    }

    .footer-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-xl);
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        font-family: "Sora", sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        margin-bottom: var(--space-xs);
    }

    .footer-logo img {
        width: 24px;
        height: 24px;
    }

    .footer-tagline {
        font-size: 0.8rem;
        color: var(--subtext);
    }

    .footer-right {
        display: flex;
        gap: var(--space-lg);
    }

    .footer-right a {
        font-size: 0.85rem;
        color: var(--subtext);
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .footer-right a:hover {
        color: var(--text);
    }

    .footer-bottom {
        max-width: var(--max-width);
        margin: 0 auto;
        padding-top: var(--space-lg);
        border-top: 1px solid var(--border);
    }

    .footer-bottom p {
        font-size: 0.75rem;
        color: var(--subtext);
    }

    @media (max-width: 640px) {
        .footer-inner {
            flex-direction: column;
            text-align: center;
            gap: var(--space-lg);
        }

        .footer-bottom {
            text-align: center;
        }
    }
</style>
