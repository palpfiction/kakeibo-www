---
import type { Locale, Translations } from "../i18n";
import { Image } from "astro:assets";
import icon from "../assets/icon.svg";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props;
const h = t.hero;
---

<section class="hero" aria-label="Hero section">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="logo fade-in">
                <Image
                    src={icon}
                    width={72}
                    height={72}
                    alt={h.logoAlt}
                />
            </div>

            <h1 class="fade-in fade-in-delay-1">{h.heading}</h1>
            <p class="hero-sub fade-in fade-in-delay-1">
                {h.subheading}
            </p>

            <p class="tagline fade-in fade-in-delay-2">
                {h.tagline}
            </p>

             <div class="hero-actions fade-in fade-in-delay-3">
                 <a href="#cta" class="beta-button">
                    <span>{h.joinBeta}</span>
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path
                            d="M12 5v14M5 12l7 7 7-7"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ></path>
                    </svg>
                 </a>
             </div>

            <div class="principles fade-in fade-in-delay-4">
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--green);"
                        aria-hidden="true"></span>
                    {h.principles.offline}
                </span>
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--blue);"
                        aria-hidden="true"></span>
                    {h.principles.privacy}
                </span>
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--red);"
                        aria-hidden="true"></span>
                    {h.principles.noAds}
                </span>
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--yellow);"
                        aria-hidden="true"></span>
                    {h.principles.noTracking}
                </span>
            </div>
        </div>

        <div class="hero-visual fade-in fade-in-delay-2">
            <div class="phone-mockup">
                <img
                    src={`/screenshots/${locale}/main.png`}
                    alt={h.screenshotAlt}
                    width="280"
                    class="hero-screenshot"
                />
            </div>
        </div>
    </div>

    <div class="scroll-indicator fade-in" aria-hidden="true">
        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </div>
</section>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-3xl) var(--space-lg) var(--space-lg);
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: "";
        position: absolute;
        top: -200px;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 600px;
        background: radial-gradient(
            ellipse at center,
            rgba(17, 138, 178, 0.08) 0%,
            rgba(6, 214, 160, 0.04) 30%,
            transparent 70%
        );
        pointer-events: none;
    }

    .hero-inner {
        max-width: var(--max-width);
        width: 100%;
        flex-grow: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-3xl);
        position: relative;
        z-index: 1;
    }

    .hero-content {
        flex: 1;
        max-width: 540px;
    }

    .hero-visual {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .logo {
        margin-bottom: var(--space-lg);
    }
    .logo img {
        width: 72px;
        height: 72px;
    }

    h1 {
        font-family: "Sora", sans-serif;
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.04em;
        margin-bottom: var(--space-sm);
    }

    .hero-sub {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 500;
        color: var(--text-secondary);
        letter-spacing: -0.01em;
        margin-bottom: var(--space-lg);
    }

    .tagline {
        font-size: clamp(0.95rem, 2vw, 1.1rem);
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-xl);
        max-width: 440px;
    }

    .hero-actions {
        margin-bottom: var(--space-xl);
        max-width: 640px;
    }

    .beta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 20px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0) 45%),
            var(--blue);
        color: var(--text);
        border-radius: var(--radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-size: 0.95rem;
        font-weight: 700;
        transition:
            transform var(--transition-normal),
            background-color var(--transition-normal),
            border-color var(--transition-normal),
            box-shadow var(--transition-normal);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.08),
            0 10px 24px rgba(17, 138, 178, 0.25);
    }

    .beta-button:hover {
        transform: translateY(-2px);
        background: #0e9ac7;
        border-color: rgba(255, 255, 255, 0.18);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.1),
            0 14px 28px rgba(17, 138, 178, 0.3);
    }

    .beta-button svg {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
        opacity: 0.9;
    }

    .principles {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .principle {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background-color: var(--surface);
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-secondary);
        border: 1px solid var(--border);
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Phone mockup */
    .phone-mockup {
        perspective: 1000px;
    }

    .hero-screenshot {
        border-radius: 36px;
        border: 2px solid var(--surface-light);
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.05),
            0 25px 50px -12px rgba(0, 0, 0, 0.5),
            0 0 80px rgba(17, 138, 178, 0.06);
        transform: rotateY(-4deg) rotateX(2deg);
        transition: transform 0.4s ease;
    }

    .hero-screenshot:hover {
        transform: rotateY(0deg) rotateX(0deg);
    }

    .scroll-indicator {
        color: var(--subtext);
        padding: var(--space-md);
        animation: bounce 2s infinite;
    }
    .scroll-indicator svg {
        width: 24px;
        height: 24px;
    }

    @keyframes bounce {
        0%,
        20%,
        50%,
        80%,
        100% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(-6px);
        }
        60% {
            transform: translateY(-3px);
        }
    }

    @media (max-width: 900px) {
        .hero-inner {
            flex-direction: column;
            text-align: center;
            justify-content: center;
        }
        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .tagline {
            max-width: 440px;
        }
        .beta-button {
            width: 100%;
            max-width: 280px;
        }
        .principles {
            justify-content: center;
        }
        .hero-visual {
            flex: none;
        }
        .hero-screenshot {
            width: 240px;
            transform: none;
        }
        .hero-screenshot:hover {
            transform: none;
        }
    }

    @media (max-width: 480px) {
        .hero {
            padding-top: var(--space-2xl);
        }
        .hero-screenshot {
            width: 220px;
        }
    }
</style>
