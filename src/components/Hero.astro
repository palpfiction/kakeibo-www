---
import type { Locale, Translations } from "../i18n";
import { Image } from "astro:assets";
import icon from "../assets/icon.svg";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props;
const h = t.hero;
const betaHref = `mailto:hola@getkakeibo.com?subject=${encodeURIComponent(h.betaEmailSubject)}&body=${encodeURIComponent(h.betaEmailBody)}`;
---

<section class="hero" aria-label="Hero section">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="logo fade-in">
                <Image
                    src={icon}
                    width={72}
                    height={72}
                    alt={h.logoAlt}
                />
            </div>

            <h1 class="fade-in fade-in-delay-1">{h.heading}</h1>
            <p class="hero-sub fade-in fade-in-delay-1">
                {h.subheading}
            </p>

            <p class="tagline fade-in fade-in-delay-2">
                {h.tagline}
            </p>

            <div class="hero-actions fade-in fade-in-delay-3">
                <a
                    href={betaHref}
                    class="beta-button"
                >
                    {h.joinBeta}
                </a>

                <div class="store-buttons">
                    <div class="store-button" aria-hidden="true">
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                            ></path>
                        </svg>
                        <span class="store-text">
                            <small>{h.appStoreLabel}</small>
                            <span>{h.appStore}</span>
                        </span>
                    </div>

                    <div class="store-button" aria-hidden="true">
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
                            ></path>
                        </svg>
                        <span class="store-text">
                            <small>{h.playStoreLabel}</small>
                            <span>{h.playStore}</span>
                        </span>
                    </div>
                </div>
                <p class="coming-soon-note">
                    {h.comingSoon}
                </p>
            </div>

            <div class="principles fade-in fade-in-delay-4">
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--green);"
                        aria-hidden="true"></span>
                    {h.principles.offline}
                </span>
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--blue);"
                        aria-hidden="true"></span>
                    {h.principles.privacy}
                </span>
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--red);"
                        aria-hidden="true"></span>
                    {h.principles.noAds}
                </span>
                <span class="principle">
                    <span
                        class="dot"
                        style="background-color: var(--yellow);"
                        aria-hidden="true"></span>
                    {h.principles.noTracking}
                </span>
            </div>
        </div>

        <div class="hero-visual fade-in fade-in-delay-2">
            <div class="phone-mockup">
                <img
                    src={`/screenshots/${locale}/main.png`}
                    alt={h.screenshotAlt}
                    width="280"
                    class="hero-screenshot"
                />
            </div>
        </div>
    </div>

    <div class="scroll-indicator fade-in" aria-hidden="true">
        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </div>
</section>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-3xl) var(--space-lg) var(--space-lg);
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: "";
        position: absolute;
        top: -200px;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 600px;
        background: radial-gradient(
            ellipse at center,
            rgba(17, 138, 178, 0.08) 0%,
            rgba(6, 214, 160, 0.04) 30%,
            transparent 70%
        );
        pointer-events: none;
    }

    .hero-inner {
        max-width: var(--max-width);
        width: 100%;
        flex-grow: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-3xl);
        position: relative;
        z-index: 1;
    }

    .hero-content {
        flex: 1;
        max-width: 540px;
    }

    .hero-visual {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .logo {
        margin-bottom: var(--space-lg);
    }
    .logo img {
        width: 72px;
        height: 72px;
    }

    h1 {
        font-family: "Sora", sans-serif;
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.04em;
        margin-bottom: var(--space-sm);
    }

    .hero-sub {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 500;
        color: var(--text-secondary);
        letter-spacing: -0.01em;
        margin-bottom: var(--space-lg);
    }

    .tagline {
        font-size: clamp(0.95rem, 2vw, 1.1rem);
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-xl);
        max-width: 440px;
    }

    .hero-actions {
        margin-bottom: var(--space-xl);
    }

    .beta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--blue);
        color: var(--text);
        padding: 14px 32px;
        border-radius: var(--radius-lg);
        font-size: 1rem;
        font-weight: 600;
        transition:
            transform var(--transition-normal),
            background-color var(--transition-normal),
            box-shadow var(--transition-normal);
        box-shadow: 0 4px 16px rgba(17, 138, 178, 0.25);
        margin-bottom: var(--space-lg);
    }

    .beta-button:hover {
        transform: translateY(-2px);
        background: #0e9ac7;
        box-shadow: 0 6px 24px rgba(17, 138, 178, 0.35);
    }

    .store-buttons {
        display: flex;
        gap: var(--space-sm);
        margin-bottom: var(--space-xs);
    }

    .store-button {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background-color: var(--surface);
        color: var(--text);
        padding: 8px 14px;
        border-radius: var(--radius-md);
        font-weight: 500;
        border: 1px solid var(--border);
        opacity: 0.3;
        filter: grayscale(1);
        pointer-events: none;
        user-select: none;
        font-size: 0.85rem;
    }

    .store-button svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .store-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1.2;
    }

    .store-text small {
        font-size: 0.6rem;
        color: var(--subtext);
        font-weight: 400;
    }
    .store-text span {
        font-size: 0.8rem;
    }

    .coming-soon-note {
        font-size: 0.75rem;
        color: var(--subtext);
        opacity: 0.6;
    }

    .principles {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .principle {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background-color: var(--surface);
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-secondary);
        border: 1px solid var(--border);
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Phone mockup */
    .phone-mockup {
        perspective: 1000px;
    }

    .hero-screenshot {
        border-radius: 36px;
        border: 2px solid var(--surface-light);
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.05),
            0 25px 50px -12px rgba(0, 0, 0, 0.5),
            0 0 80px rgba(17, 138, 178, 0.06);
        transform: rotateY(-4deg) rotateX(2deg);
        transition: transform 0.4s ease;
    }

    .hero-screenshot:hover {
        transform: rotateY(0deg) rotateX(0deg);
    }

    .scroll-indicator {
        color: var(--subtext);
        padding: var(--space-md);
        animation: bounce 2s infinite;
    }
    .scroll-indicator svg {
        width: 24px;
        height: 24px;
    }

    @keyframes bounce {
        0%,
        20%,
        50%,
        80%,
        100% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(-6px);
        }
        60% {
            transform: translateY(-3px);
        }
    }

    @media (max-width: 900px) {
        .hero-inner {
            flex-direction: column;
            text-align: center;
            justify-content: center;
        }
        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .tagline {
            max-width: 440px;
        }
        .beta-button {
            width: 100%;
            max-width: 280px;
        }
        .store-buttons {
            justify-content: center;
        }
        .principles {
            justify-content: center;
        }
        .hero-visual {
            flex: none;
        }
        .hero-screenshot {
            width: 240px;
            transform: none;
        }
        .hero-screenshot:hover {
            transform: none;
        }
    }

    @media (max-width: 480px) {
        .hero {
            padding-top: var(--space-2xl);
        }
        .store-buttons {
            flex-direction: column;
            align-items: center;
        }
        .store-button {
            width: 100%;
            max-width: 200px;
            justify-content: center;
        }
        .hero-screenshot {
            width: 220px;
        }
    }
</style>
