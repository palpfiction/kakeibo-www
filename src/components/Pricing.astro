---
import type { Locale, Translations } from "../i18n";

interface Props {
    locale: Locale;
    t: Translations;
}

const { t } = Astro.props;
const pr = t.pricing;
---

<section class="section pricing" id="pricing">
    <div class="section-inner">
        <div class="section-header fade-in">
            <h2 class="section-title">{pr.title}</h2>
            <p class="section-subtitle">{pr.subtitle}</p>
        </div>

        <div class="pricing-contrast fade-in">
            <div class="pricing-contrast-item negative">
                <h4>{pr.subscriptions.title}</h4>
                <ul>
                    {pr.subscriptions.items.map((item: string) => <li>{item}</li>)}
                </ul>
            </div>
            <div class="pricing-contrast-divider">
                <span>{pr.vs}</span>
            </div>
            <div class="pricing-contrast-item positive">
                <h4>{pr.kakeibo.title}</h4>
                <ul>
                    {pr.kakeibo.items.map((item: string) => <li>{item}</li>)}
                </ul>
            </div>
        </div>
    </div>
</section>

<style>
    .pricing {
        background: var(--bg);
    }

    /* Comparison */
    .pricing-contrast {
        display: flex;
        align-items: stretch;
        gap: var(--space-lg);
        max-width: 640px;
        margin: 0 auto;
    }

    .pricing-contrast-item {
        flex: 1;
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
    }

    .pricing-contrast-item.negative {
        background: rgba(239, 71, 111, 0.06);
        border: 1px solid rgba(239, 71, 111, 0.15);
    }

    .pricing-contrast-item.positive {
        background: rgba(6, 214, 160, 0.06);
        border: 1px solid rgba(6, 214, 160, 0.15);
    }

    .pricing-contrast-item h4 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: var(--space-md);
    }

    .pricing-contrast-item.negative h4 {
        color: var(--red);
    }

    .pricing-contrast-item.positive h4 {
        color: var(--green);
    }

    .pricing-contrast-item ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .pricing-contrast-item ul li {
        font-size: 0.85rem;
        color: var(--subtext);
        padding-left: 16px;
        position: relative;
    }

    .pricing-contrast-item.negative ul li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 7px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--red);
        opacity: 0.5;
    }

    .pricing-contrast-item.positive ul li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 7px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        opacity: 0.5;
    }

    .pricing-contrast-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .pricing-contrast-divider span {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--subtext);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    @media (max-width: 640px) {
        .pricing-contrast {
            flex-direction: column;
        }

        .pricing-contrast-divider span {
            padding: 0;
        }
    }
</style>
