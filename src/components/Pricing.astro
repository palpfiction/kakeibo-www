---

<section class="section pricing" id="pricing">
    <div class="section-inner">
        <div class="section-header fade-in">
            <h2 class="section-title">One price. Forever yours.</h2>
            <p class="section-subtitle">
                No subscriptions. No in-app purchases. No premium tiers. Pay
                once, use forever. Regional pricing. We think that's how
                software should work.
            </p>
        </div>

        <div class="pricing-contrast fade-in">
            <div class="pricing-contrast-item negative">
                <h4>Subscription apps</h4>
                <ul>
                    <li>$5&ndash;15/month, forever</li>
                    <li>Your data on their servers</li>
                    <li>Ads and upsells</li>
                    <li>Lose access if you stop paying</li>
                </ul>
            </div>
            <div class="pricing-contrast-divider">
                <span>vs.</span>
            </div>
            <div class="pricing-contrast-item positive">
                <h4>Kakeibo</h4>
                <ul>
                    <li>One-time purchase</li>
                    <li>Data stays on your device</li>
                    <li>No ads, no upsells</li>
                    <li>Yours forever</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<style>
    .pricing {
        background: var(--bg);
    }

    .pricing-card {
        max-width: 440px;
        margin: 0 auto var(--space-3xl);
    }

    .pricing-card-inner {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-2xl);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .pricing-card-inner::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--green), var(--blue));
    }

    .pricing-top {
        margin-bottom: var(--space-lg);
    }

    .pricing-headline {
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: var(--space-xs);
    }

    .pricing-period {
        font-size: 0.9rem;
        color: var(--subtext);
        font-weight: 500;
    }

    .pricing-divider {
        height: 1px;
        background: var(--border);
        margin: var(--space-lg) 0;
    }

    .pricing-features {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        text-align: left;
        margin-bottom: var(--space-xl);
    }

    .pricing-features li {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .pricing-features li svg {
        flex-shrink: 0;
    }

    .pricing-comparison {
        background: var(--surface);
        border-radius: var(--radius-md);
        padding: var(--space-md);
    }

    .pricing-comparison-label {
        font-size: 0.9rem;
        font-weight: 600;
        display: block;
    }

    /* Comparison */
    .pricing-contrast {
        display: flex;
        align-items: stretch;
        gap: var(--space-lg);
        max-width: 640px;
        margin: 0 auto;
    }

    .pricing-contrast-item {
        flex: 1;
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
    }

    .pricing-contrast-item.negative {
        background: rgba(239, 71, 111, 0.06);
        border: 1px solid rgba(239, 71, 111, 0.15);
    }

    .pricing-contrast-item.positive {
        background: rgba(6, 214, 160, 0.06);
        border: 1px solid rgba(6, 214, 160, 0.15);
    }

    .pricing-contrast-item h4 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: var(--space-md);
    }

    .pricing-contrast-item.negative h4 {
        color: var(--red);
    }

    .pricing-contrast-item.positive h4 {
        color: var(--green);
    }

    .pricing-contrast-item ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .pricing-contrast-item ul li {
        font-size: 0.85rem;
        color: var(--subtext);
        padding-left: 16px;
        position: relative;
    }

    .pricing-contrast-item.negative ul li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 7px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--red);
        opacity: 0.5;
    }

    .pricing-contrast-item.positive ul li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 7px;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        opacity: 0.5;
    }

    .pricing-contrast-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .pricing-contrast-divider span {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--subtext);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    @media (max-width: 640px) {
        .pricing-contrast {
            flex-direction: column;
        }

        .pricing-contrast-divider span {
            padding: 0;
        }
    }
</style>
