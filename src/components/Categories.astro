---
import type { Locale, Translations } from "../i18n";

interface Props {
    locale: Locale;
    t: Translations;
}

const { t } = Astro.props;
const c = t.categories;

const items = [
    { key: c.needs, color: "var(--dark-green)", width: "45%" },
    { key: c.wants, color: "var(--red)", width: "28%", delay: "fade-in-delay-1" },
    { key: c.culture, color: "var(--dark-yellow)", width: "17%", delay: "fade-in-delay-2" },
    { key: c.unexpected, color: "var(--dark-blue)", width: "10%", delay: "fade-in-delay-3" },
];
---

<section class="section categories" id="categories">
    <div class="section-inner">
        <div class="section-header fade-in">
            <h2 class="section-title">{c.title}</h2>
            <p class="section-subtitle">{c.subtitle}</p>
        </div>

        <div class="categories-grid">
            {items.map((item) => (
                <div
                    class={`category-card fade-in ${item.delay || ""}`}
                    style={`--cat-color: ${item.color};`}
                >
                    <div class="category-header">
                        <span
                            class="category-dot"
                            style={`background: ${item.color};`}
                        />
                        <h3>{item.key.title}</h3>
                    </div>
                    <p class="category-description">{item.key.description}</p>
                    <div class="category-examples">
                        {item.key.tags.map((tag: string) => (
                            <span class="category-tag">{tag}</span>
                        ))}
                    </div>
                    <div class="category-bar">
                        <div
                            class="category-bar-fill"
                            style={`width: ${item.width}; background: ${item.color};`}
                        />
                    </div>
                    <span class="category-percent">{item.key.percent}</span>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .categories-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-lg);
    }

    .category-card {
        background: var(--bg-elevated);
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
        transition:
            transform var(--transition-normal),
            box-shadow var(--transition-normal);
        position: relative;
    }

    .category-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .category-header {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        margin-bottom: var(--space-md);
    }

    .category-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .category-header h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--cat-color);
    }

    .category-description {
        font-size: 0.9rem;
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-md);
    }

    .category-examples {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
        margin-bottom: var(--space-lg);
    }

    .category-tag {
        font-size: 0.75rem;
        background: rgba(255, 255, 255, 0.04);
        padding: 4px 10px;
        border-radius: var(--radius-pill);
        color: var(--text-secondary);
    }

    .category-bar {
        height: 4px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: var(--radius-pill);
        margin-bottom: var(--space-sm);
        overflow: hidden;
    }

    .category-bar-fill {
        height: 100%;
        border-radius: var(--radius-pill);
        transition: width 1.2s ease;
    }

    .category-percent {
        font-size: 0.75rem;
        color: var(--subtext);
        font-weight: 500;
    }

    @media (max-width: 768px) {
        .categories-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
