---
import type { Locale, Translations } from "../i18n";

interface Props {
    locale: Locale;
    t: Translations;
}

const { t } = Astro.props;
const p = t.privacy;
---

<section class="section privacy" id="privacy">
    <div class="section-inner">
        <div class="section-header fade-in">
            <h2 class="section-title">{p.title}</h2>
            <p class="section-subtitle">{p.subtitle}</p>
        </div>

        <div class="privacy-grid">
            <div class="privacy-card fade-in">
                <div
                    class="privacy-icon"
                    style="background: rgba(6, 214, 160, 0.1);"
                >
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--green)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M2 20h.01"></path><path d="M7 20v-4"
                        ></path><path d="M12 20v-8"></path><path d="M17 20V8"
                        ></path><path d="M22 4v16"></path>
                    </svg>
                </div>
                <h3>{p.offline.title}</h3>
                <p>{p.offline.description}</p>
            </div>

            <div class="privacy-card fade-in fade-in-delay-1">
                <div
                    class="privacy-icon"
                    style="background: rgba(17, 138, 178, 0.1);"
                >
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--blue)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                        ></path>
                    </svg>
                </div>
                <h3>{p.privacyFirst.title}</h3>
                <p>{p.privacyFirst.description}</p>
            </div>

            <div class="privacy-card fade-in fade-in-delay-2">
                <div
                    class="privacy-icon"
                    style="background: rgba(239, 71, 111, 0.1);"
                >
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--red)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2"
                        ></rect><path d="m3 3 18 18"></path>
                    </svg>
                </div>
                <h3>{p.noAds.title}</h3>
                <p>{p.noAds.description}</p>
            </div>

            <div class="privacy-card fade-in fade-in-delay-3">
                <div
                    class="privacy-icon"
                    style="background: rgba(255, 209, 102, 0.1);"
                >
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--yellow)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </div>
                <h3>{p.dataExport.title}</h3>
                <p>{p.dataExport.description}</p>
            </div>
        </div>
    </div>
</section>

<style>
    .privacy {
        background: var(--bg-elevated);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
    }

    .privacy-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-lg);
    }

    .privacy-card {
        background: var(--surface);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-xl);
        transition: transform var(--transition-normal);
    }

    .privacy-card:hover {
        transform: translateY(-4px);
    }

    .privacy-icon {
        width: 52px;
        height: 52px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-lg);
    }

    .privacy-card h3 {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: var(--space-sm);
    }

    .privacy-card p {
        font-size: 0.9rem;
        color: var(--subtext);
        line-height: 1.7;
    }

    @media (max-width: 640px) {
        .privacy-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
