---
import type { Locale, Translations } from "../i18n";

interface Props {
    locale: Locale;
    t: Translations;
    /** Optional sub-path to append, e.g. "privacy" → /es/privacy/ */
    path?: string;
    /** Optional explicit href map, useful when localized slugs differ. */
    hrefs?: Partial<Record<Locale, string>>;
    /**
     * Whether the switcher is fixed-positioned (default: true).
     * Pass false when embedding inside a header.
     */
    fixed?: boolean;
}

const { locale, path, hrefs, fixed = true } = Astro.props;
const otherLocale: Locale = locale === "en" ? "es" : "en";
const otherLabel = otherLocale === "en" ? "EN" : "ES";
const otherHref =
    hrefs?.[otherLocale] ??
    (path ? `/${otherLocale}/${path}/` : `/${otherLocale}/`);
---

<nav class:list={["lang-switcher", { "lang-switcher--fixed": fixed }]} aria-label="Language">
    <a
        href={otherHref}
        class="lang-link"
        aria-label={otherLocale === "en" ? "Switch to English" : "Cambiar a Español"}
    >
        <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M2 12h20"></path>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        {otherLabel}
    </a>
</nav>

<style>
    .lang-switcher--fixed {
        position: fixed;
        top: var(--space-md);
        right: var(--space-md);
        z-index: 100;
    }

    .lang-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--surface);
        border: 1px solid var(--border-light);
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-secondary);
        transition:
            background-color var(--transition-fast),
            color var(--transition-fast),
            border-color var(--transition-fast);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .lang-link:hover {
        background: var(--surface-hover);
        color: var(--text);
        border-color: rgba(255, 255, 255, 0.15);
    }

    .lang-link svg {
        opacity: 0.7;
    }
</style>
