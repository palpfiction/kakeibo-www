---
import type { Locale, Translations } from "../i18n";
import { Image } from "astro:assets";
import icon from "../assets/icon.svg";
import PageFooter from "./PageFooter.astro";
import BetaAccess from "./BetaAccess.astro";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props;
const ct = t.cta;
---

<section class="section cta" id="cta">
    <div class="section-inner">
        <div class="cta-content fade-in">
            <Image src={icon} width={56} height={56} alt="" class="cta-logo" />
            <h2>{ct.heading}</h2>
            <p>{ct.description}</p>

            <BetaAccess locale={locale} t={t} />
        </div>
    </div>
</section>

<PageFooter locale={locale} t={t} />

<style>
    .cta {
        background: var(--bg-elevated);
        border-top: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .cta::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 400px;
        background: radial-gradient(
            ellipse at center,
            rgba(6, 214, 160, 0.05) 0%,
            rgba(17, 138, 178, 0.03) 40%,
            transparent 70%
        );
        pointer-events: none;
    }

    .cta-content {
        text-align: center;
        max-width: 520px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .cta-content img {
        width: 56px;
        height: 56px;
        margin: 0 auto var(--space-lg);
    }

    .cta-content h2 {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: var(--space-md);
    }

    .cta-content p {
        font-size: 1rem;
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-lg);
    }
</style>
