---
import type { Locale, Translations } from "../i18n";
import { Image } from "astro:assets";
import icon from "../assets/icon.svg";
import PageFooter from "./PageFooter.astro";

interface Props {
    locale: Locale;
    t: Translations;
}

const { locale, t } = Astro.props;
const ct = t.cta;
const betaHref = `mailto:hola@getkakeibo.com?subject=${encodeURIComponent(ct.betaEmailSubject)}&body=${encodeURIComponent(ct.betaEmailBody)}`;
---

<section class="section cta" id="cta">
    <div class="section-inner">
        <div class="cta-content fade-in">
            <Image src={icon} width={56} height={56} alt="" class="cta-logo" />
            <h2>{ct.heading}</h2>
            <p>{ct.description}</p>

            <a
                href={betaHref}
                class="cta-beta-button"
            >
                {ct.joinBeta}
            </a>

            <div class="cta-store-row">
                <div class="cta-store-button" aria-hidden="true">
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                        ></path>
                    </svg>
                    <span class="cta-store-text">
                        <small>{ct.appStoreLabel}</small>
                        <span>{ct.appStore}</span>
                    </span>
                </div>

                <div class="cta-store-button" aria-hidden="true">
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
                        ></path>
                    </svg>
                    <span class="cta-store-text">
                        <small>{ct.playStoreLabel}</small>
                        <span>{ct.playStore}</span>
                    </span>
                </div>
            </div>
            <p class="cta-coming-soon">
                {ct.comingSoon}
            </p>
        </div>
    </div>
</section>

<PageFooter locale={locale} t={t} />

<style>
    .cta {
        background: var(--bg-elevated);
        border-top: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .cta::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 400px;
        background: radial-gradient(
            ellipse at center,
            rgba(6, 214, 160, 0.05) 0%,
            rgba(17, 138, 178, 0.03) 40%,
            transparent 70%
        );
        pointer-events: none;
    }

    .cta-content {
        text-align: center;
        max-width: 520px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .cta-content img {
        width: 56px;
        height: 56px;
        margin: 0 auto var(--space-lg);
    }

    .cta-content h2 {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: var(--space-md);
    }

    .cta-content p {
        font-size: 1rem;
        color: var(--subtext);
        line-height: 1.7;
        margin-bottom: var(--space-lg);
    }

    .cta-beta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--blue);
        color: var(--text);
        padding: 14px 32px;
        border-radius: var(--radius-lg);
        font-size: 1rem;
        font-weight: 600;
        transition:
            transform var(--transition-normal),
            background-color var(--transition-normal),
            box-shadow var(--transition-normal);
        box-shadow: 0 4px 16px rgba(17, 138, 178, 0.25);
        margin-bottom: var(--space-xl);
    }

    .cta-beta-button:hover {
        transform: translateY(-2px);
        background: #0e9ac7;
        box-shadow: 0 6px 24px rgba(17, 138, 178, 0.35);
    }

    .cta-store-row {
        display: flex;
        gap: var(--space-sm);
        justify-content: center;
        margin-bottom: var(--space-xs);
    }

    .cta-store-button {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background-color: var(--surface);
        color: var(--text);
        padding: 8px 14px;
        border-radius: var(--radius-md);
        font-weight: 500;
        border: 1px solid var(--border);
        opacity: 0.3;
        filter: grayscale(1);
        pointer-events: none;
        user-select: none;
        font-size: 0.85rem;
    }

    .cta-store-button svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .cta-store-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1.2;
    }

    .cta-store-text small {
        font-size: 0.6rem;
        color: var(--subtext);
        font-weight: 400;
    }

    .cta-store-text span {
        font-size: 0.8rem;
    }

    .cta-coming-soon {
        font-size: 0.75rem;
        color: var(--subtext);
        opacity: 0.6;
        margin-bottom: 0;
    }

    @media (max-width: 640px) {
        .cta-beta-button {
            width: 100%;
            max-width: 280px;
        }

        .cta-store-row {
            flex-direction: column;
            align-items: center;
        }

        .cta-store-button {
            width: 100%;
            max-width: 200px;
            justify-content: center;
        }
    }
</style>

